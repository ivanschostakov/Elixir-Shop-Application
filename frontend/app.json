{
  "expo": {
    "name": "Elixir Shop",
    "slug": "elixir-shop",
    "version": "0.1.0",
    "orientation": "portrait",
    "icon": "./assets/images/adaptive-icon-preview.png",
    "scheme": "elixirshopapp",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "icon": "./assets/images/adaptive-icon-preview.png",
      "bundleIdentifier": "com.ivanschostakov.elixirshopapp",
      "buildNumber": "1",
      "associatedDomains": [
        "applinks:elixirshop.devsivanschostakov.org"
      ],
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false,
        "NSLocationWhenInUseUsageDescription": "Allow Elixir Shop to access your location so the delivery map can center on you."
      }
    },
    "android": {
      "icon": "./assets/images/adaptive-icon-preview.png",
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/images/adaptive-icon-foreground.png",
        "backgroundImage": "./assets/images/adaptive-icon-background.png",
        "monochromeImage": "./assets/images/adaptive-icon-monochrome.png"
      },
      "edgeToEdgeEnabled": true,
      "package": "com.ivanschostakov.elixirshopapp",
      "versionCode": 1,
      "blockedPermissions": [
        "android.permission.RECORD_AUDIO",
        "android.permission.SYSTEM_ALERT_WINDOW"
      ],
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.ACCESS_FINE_LOCATION"
      ]
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      "./plugins/with-yandex-mapkit",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#ffffff",
          "dark": {
            "backgroundColor": "#000000"
          }
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Allow Elixir Shop to access your photos so you can choose a profile picture.",
          "cameraPermission": "Allow Elixir Shop to access your camera so you can take profile pictures.",
          "microphonePermission": false
        }
      ],
      [
        "expo-camera",
        {
          "cameraPermission": "Allow Elixir Shop to access your camera so you can take profile pictures.",
          "microphonePermission": false,
          "recordAudioAndroid": false
        }
      ],
      [
        "expo-notifications",
        {
          "mode": "production"
        }
      ],
      "expo-secure-store"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "32dfb6b0-55a1-4dcc-aeab-91b3633cfed6"
      }
    },
    "owner": "elixir-peptide"
  }
}
