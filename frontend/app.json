{
  "expo": {
    "name": "Elixir Peptide",
    "slug": "elixir-shop",
    "version": "0.1.1",
    "orientation": "portrait",
    "icon": "./assets/images/adaptive-icon-preview.png",
    "scheme": "elixirpeptide",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/32dfb6b0-55a1-4dcc-aeab-91b3633cfed6"
    },
    "ios": {
      "supportsTablet": true,
      "icon": "./assets/images/adaptive-icon-preview.png",
      "bundleIdentifier": "com.ivanschostakov.elixirshopapp",
      "buildNumber": "2",
      "associatedDomains": [
        "applinks:elixirshop.devsivanschostakov.org"
      ],
      "entitlements": {
        "com.apple.developer.devicecheck.appattest-environment": "production"
      },
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false,
        "NSLocationWhenInUseUsageDescription": "Allow Elixir Peptide to access your location so the delivery map can center on you.",
        "NSMicrophoneUsageDescription": "Allow Elixir Peptide to record voice messages for AI chat."
      }
    },
    "android": {
      "icon": "./assets/images/adaptive-icon-preview.png",
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/images/adaptive-icon-foreground.png",
        "backgroundImage": "./assets/images/adaptive-icon-background.png",
        "monochromeImage": "./assets/images/adaptive-icon-monochrome.png"
      },
      "edgeToEdgeEnabled": true,
      "requestLegacyExternalStorage": false,
      "package": "com.elixirpeptide.elixirpeptide",
      "versionCode": 2,
      "blockedPermissions": [
        "android.permission.SYSTEM_ALERT_WINDOW",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.WRITE_EXTERNAL_STORAGE",
        "android.permission.READ_MEDIA_IMAGES",
        "android.permission.READ_MEDIA_VIDEO",
        "android.permission.READ_MEDIA_VISUAL_USER_SELECTED"
      ],
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.RECORD_AUDIO"
      ]
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-build-properties",
        {
          "android": {
            "minSdkVersion": 26
          }
        }
      ],
      "./plugins/with-yandex-mapkit",
      "./plugins/with-app-attest-environment",
      "./plugins/with-android-play-policy-permissions",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "resizeMode": "contain",
          "imageWidth": 220,
          "backgroundColor": "#2D6AA3",
          "dark": {
            "image": "./assets/images/splash-icon.png",
            "backgroundColor": "#2D6AA3"
          }
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Allow Elixir Peptide to access your photos so you can attach images to chat messages.",
          "cameraPermission": "Allow Elixir Peptide to access your camera so you can take profile pictures."
        }
      ],
      [
        "expo-camera",
        {
          "cameraPermission": "Allow Elixir Peptide to access your camera so you can take profile pictures.",
          "recordAudioAndroid": false
        }
      ],
      [
        "expo-notifications",
        {
          "mode": "production"
        }
      ],
      "expo-secure-store",
      [
        "expo-audio",
        {
          "microphonePermission": "Allow Elixir Peptide to record voice messages for AI chat."
        }
      ],
      "expo-asset"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "32dfb6b0-55a1-4dcc-aeab-91b3633cfed6"
      }
    },
    "owner": "elixir-peptide"
  }
}
