{
  "extends": "expo/tsconfig.base",
  "compilerOptions": {
    "moduleSuffixes": [
      ".native",
      ".web",
      ""
    ],
    "strict": true,
    "paths": {
      "@/*": [
        "./*"
      ]
    }
  },
  "include": [
    "**/*.ts",
    "**/*.tsx",
    ".expo/types/**/*.ts",
    "expo-env.d.ts"
  ],
  "exclude": [
    "node_modules",
    ".expo",
    "dist",
    "web-build",
    "backups",
    "web-backup",
    "scripts/react-native-yamap-patches"
  ]
}
